# ─── Backend ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://vitashelf:your_password@db:5432/vitashelf
JWT_SECRET=change-me-to-a-long-random-secret
NODE_ENV=production
PORT=4000
CORS_ORIGIN=https://your-domain.com
UPLOAD_DIR=/app/uploads

# ─── Google SSO (optional) ───────────────────────────────────────────────────
# GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# ─── Database Encryption (optional) ──────────────────────────────────────────
# DB_ENCRYPTION_KEY=your-long-random-encryption-key

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_USER=vitashelf
POSTGRES_PASSWORD=your_password
POSTGRES_DB=vitashelf

# ─── Docker Compose Production ────────────────────────────────────────────────
GITHUB_REPOSITORY=your-github-username/VitaShelf
IMAGE_TAG=latest
